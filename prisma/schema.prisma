generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  password     String
  nickname     String?
  createdAt    DateTime       @default(now()) @map("created_at")
  desks        DeskObject[]
  challenges   Challenge[]
  focusLogs    FocusLog[]
  focusSessions FocusSession[]
  todos        Todo[]
  plantWaterings PlantWatering[]
  bookReviews  BookReview[]
  deskSetting  DeskSetting?

  @@map("users")
}

model DeskObject {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  objectName String   @map("object_name")
  posX       Float    @map("pos_x")
  posY       Float    @map("pos_y")
  isActive   Boolean  @default(true) @map("is_active")
  volume     Float    @default(0.5)
  scale      Float    @default(1)
  imageData  String?  @map("image_data")
  variant    String?
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("desk_objects")
}

model DeskSetting {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  backgroundId    String   @default("default") @map("background_id")
  backgroundImage String?  @map("background_image")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("desk_settings")
}

model Challenge {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  user            User      @relation(fields: [userId], references: [id])
  title           String
  totalPages      Int       @map("total_pages")
  currentPages    Int       @default(0) @map("current_pages")
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  totalFocusTime  Int       @default(0) @map("total_focus_time")
  status          ChallengeStatus @default(PROGRESS)
  createdAt       DateTime  @default(now()) @map("created_at")
  focusLogs       FocusLog[]

  @@map("challenges")
}

enum ChallengeStatus {
  PROGRESS
  COMPLETED
  FAIL
}

model FocusLog {
  id              Int        @id @default(autoincrement())
  userId          Int        @map("user_id")
  user            User       @relation(fields: [userId], references: [id])
  challengeId     Int?       @map("challenge_id")
  challenge       Challenge? @relation(fields: [challengeId], references: [id])
  focusDuration   Int        @map("focus_duration")
  audioPresetName String?    @map("audio_preset_name")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@map("focus_logs")
}

/// A named, resumable focus record (e.g. "수학 숙제", "토지 3권 읽기"). Unlike
/// FocusLog (one-off completed timer entries), a session accumulates time
/// across multiple start/pause cycles and can be picked later to build a
/// share card.
model FocusSession {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  name         String
  totalSeconds Int      @default(0) @map("total_seconds")
  isCompleted  Boolean  @default(false) @map("is_completed")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("focus_sessions")
}

model Todo {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  title        String
  isDone       Boolean  @default(false) @map("is_done")
  focusSeconds Int      @default(0) @map("focus_seconds")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("todos")
}

model PlantWatering {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  wateredDate DateTime @map("watered_date")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, wateredDate])
  @@map("plant_waterings")
}

model BookReview {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  bookTitle   String   @map("book_title")
  summary     String?
  review      String?
  quote       String?
  food        String?
  music       String?
  showDuration Boolean @default(false) @map("show_duration")
  showWeatherNote Boolean @default(false) @map("show_weather_note")
  todayActivity String? @map("today_activity")
  durationMinutes Int? @map("duration_minutes")
  rating      Int      @default(5)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("book_reviews")
}

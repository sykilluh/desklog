generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int             @id @default(autoincrement())
  email            String          @unique
  password         String
  nickname         String?
  /// 주간/월간 분석 패널의 "목표 달성률"이 비교 대상으로 쓰는 하루 집중 목표(분).
  dailyGoalMinutes Int             @default(60) @map("daily_goal_minutes")
  createdAt        DateTime        @default(now()) @map("created_at")
  desks            DeskObject[]
  challenges       Challenge[]
  focusLogs        FocusLog[]
  focusSessions    FocusSession[]
  subjectDailyLogs SubjectDailyLog[]
  todos            Todo[]
  plantWaterings   PlantWatering[]
  bookReviews      BookReview[]
  deskSetting      DeskSetting?

  @@map("users")
}

model DeskObject {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  objectName String   @map("object_name")
  posX       Float    @map("pos_x")
  posY       Float    @map("pos_y")
  isActive   Boolean  @default(true) @map("is_active")
  volume     Float    @default(0.5)
  scale      Float    @default(1)
  imageData  String?  @map("image_data")
  variant    String?
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("desk_objects")
}

model DeskSetting {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  backgroundId    String   @default("default") @map("background_id")
  backgroundImage String?  @map("background_image")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("desk_settings")
}

model Challenge {
  id             Int             @id @default(autoincrement())
  userId         Int             @map("user_id")
  user           User            @relation(fields: [userId], references: [id])
  title          String
  totalPages     Int             @map("total_pages")
  currentPages   Int             @default(0) @map("current_pages")
  startDate      DateTime        @map("start_date")
  endDate        DateTime        @map("end_date")
  totalFocusTime Int             @default(0) @map("total_focus_time")
  status         ChallengeStatus @default(PROGRESS)
  createdAt      DateTime        @default(now()) @map("created_at")
  focusLogs      FocusLog[]

  @@map("challenges")
}

enum ChallengeStatus {
  PROGRESS
  COMPLETED
  FAIL
}

model FocusLog {
  id              Int        @id @default(autoincrement())
  userId          Int        @map("user_id")
  user            User       @relation(fields: [userId], references: [id])
  challengeId     Int?       @map("challenge_id")
  challenge       Challenge? @relation(fields: [challengeId], references: [id])
  focusDuration   Int        @map("focus_duration")
  audioPresetName String?    @map("audio_preset_name")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@map("focus_logs")
}

/// A named, resumable focus record (e.g. "수학 숙제", "토지 3권 읽기"). Unlike
/// FocusLog (one-off completed timer entries), a session accumulates time
/// across multiple start/pause cycles and can be picked later to build a
/// share card.
model FocusSession {
  id                 Int              @id @default(autoincrement())
  userId             Int              @map("user_id")
  user               User             @relation(fields: [userId], references: [id])
  name               String
  /// 뽀모도로/타이머(스톱워치)는 단위가 다른 시간 기록이라 한 레코드에 섞이지 않도록
  /// 생성 시점의 모드를 고정해서 저장한다 — 이어하기도 항상 이 모드로 강제된다.
  mode               FocusSessionMode @default(POMODORO)
  totalSeconds       Int              @default(0) @map("total_seconds")
  /// Snapshot of the live timer at the moment this record was last
  /// stopped·저장 — pomodoro's remaining countdown in `lastPhase`, or the
  /// stopwatch's elapsed count. Resuming restores the timer to exactly this
  /// position instead of restarting the full preset / 0:00.
  lastSeconds        Int              @default(0) @map("last_seconds")
  lastPhase          String           @default("focus") @map("last_phase")
  presetFocusMinutes Int              @default(25) @map("preset_focus_minutes")
  presetBreakMinutes Int              @default(5) @map("preset_break_minutes")
  isCompleted        Boolean          @default(false) @map("is_completed")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@map("focus_sessions")
}

/// 같은 이름(과목)으로 들어온 집중 시간을 날짜별로 따로 쌓아두는 표 — FocusSession은
/// "수학"을 여러 날에 걸쳐 이어해도 누적 총합만 남기지만, 이건 그 누적이 어느 날
/// 얼마씩 쌓였는지를 (subjectName, date) 단위로 보존해서 다이어리에서 월별로
/// "수학: 6/1 30분, 6/2 45분..." 식으로 펼쳐볼 수 있게 한다.
model SubjectDailyLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  subjectName String   @map("subject_name")
  /// Local calendar day at midnight — not a timestamp.
  date        DateTime
  seconds     Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, subjectName, date])
  @@map("subject_daily_logs")
}

enum FocusSessionMode {
  POMODORO
  STOPWATCH
}

model Todo {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  title        String
  isDone       Boolean  @default(false) @map("is_done")
  focusSeconds Int      @default(0) @map("focus_seconds")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("todos")
}

model PlantWatering {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  wateredDate DateTime @map("watered_date")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, wateredDate])
  @@map("plant_waterings")
}

model BookReview {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  bookTitle       String   @map("book_title")
  summary         String?
  review          String?
  quote           String?
  food            String?
  music           String?
  showDuration    Boolean  @default(false) @map("show_duration")
  showWeatherNote Boolean  @default(false) @map("show_weather_note")
  todayActivity   String?  @map("today_activity")
  durationMinutes Int?     @map("duration_minutes")
  rating          Int      @default(5)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("book_reviews")
}
